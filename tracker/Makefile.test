# Test makefile
CC = cc
CFLAGS = -std=c99 -Wall -g

# Directories
LIB_DIR = ../chipnomad_lib
TRACKER_DIR = src
UNITY_DIR = external/unity
MOCK_DIR = tests/mocks
TEST_DIR = tests

# Include paths
INCLUDES = -I$(UNITY_DIR) \
           -I$(LIB_DIR) \
           -I$(LIB_DIR)/corelib \
           -I$(LIB_DIR)/corelib_file_stdio \
           -I$(TRACKER_DIR) \
           -I$(TRACKER_DIR)/corelib \
           -I$(TRACKER_DIR)/screens \
           -Iplatforms/shared

# Unity
UNITY_SRC = $(UNITY_DIR)/unity.c

# Mock sources
MOCK_SRC = $(wildcard $(MOCK_DIR)/*.c)

# Library sources needed by tests
LIB_SRC = $(LIB_DIR)/project.c \
          $(LIB_DIR)/project_io.c \
          $(LIB_DIR)/project_instruments_io.c \
          $(LIB_DIR)/utils.c

# Full library sources needed by playback tests
LIB_PLAYBACK_SRC = $(LIB_SRC) \
                   $(LIB_DIR)/chipnomad_lib.c \
                   $(LIB_DIR)/playback.c \
                   $(LIB_DIR)/playback_ay.c \
                   $(LIB_DIR)/playback_fx_common.c \
                   $(LIB_DIR)/playback_fx_ay.c

# Tracker sources needed by tracker tests
TRACKER_SRC = $(TRACKER_DIR)/project_utils.c

# Screen sources needed by edit_common tests
EDIT_COMMON_SRC = $(TRACKER_DIR)/screens/edit_common.c

# Real file system implementation
REAL_FILE_SRC = $(LIB_DIR)/corelib_file_stdio/corelib_file_stdio.c

# Build directory
BUILD = build/test

# All test files
ALL_TESTS = $(wildcard $(TEST_DIR)/test_*.c)

# Test executables
ALL_BINS = $(patsubst $(TEST_DIR)/test_%.c,$(BUILD)/test_%,$(ALL_TESTS))

all: $(ALL_BINS)

# Playback tests need the full playback engine + pitch table utils
$(BUILD)/test_playback: $(TEST_DIR)/test_playback.c $(LIB_PLAYBACK_SRC) $(TRACKER_DIR)/pitch_table_utils.c $(UNITY_SRC) $(MOCK_SRC) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $< $(LIB_PLAYBACK_SRC) $(TRACKER_DIR)/pitch_table_utils.c $(UNITY_SRC) $(filter-out $(MOCK_DIR)/pitch_table_utils_mock.c,$(MOCK_SRC)) -lm

# Project I/O tests use real file system (not mocked)
$(BUILD)/test_project_io: $(TEST_DIR)/test_project_io.c $(LIB_SRC) $(REAL_FILE_SRC) $(UNITY_SRC) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $< $(LIB_SRC) $(REAL_FILE_SRC) $(UNITY_SRC) -lm

# Project tests use mocks
$(BUILD)/test_project: $(TEST_DIR)/test_project.c $(LIB_SRC) $(UNITY_SRC) $(MOCK_SRC) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $< $(LIB_SRC) $(UNITY_SRC) $(MOCK_SRC) -lm

# Edit common tests: lib + edit_common + unity + mocks
$(BUILD)/test_edit_common: $(TEST_DIR)/test_edit_common.c $(LIB_SRC) $(EDIT_COMMON_SRC) $(UNITY_SRC) $(MOCK_SRC) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $< $(LIB_SRC) $(EDIT_COMMON_SRC) $(UNITY_SRC) $(MOCK_SRC) -lm

# Tracker tests: lib + tracker sources + unity + mocks
$(BUILD)/test_%: $(TEST_DIR)/test_%.c $(LIB_SRC) $(TRACKER_SRC) $(UNITY_SRC) $(MOCK_SRC) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $< $(LIB_SRC) $(TRACKER_SRC) $(UNITY_SRC) $(MOCK_SRC) -lm

$(BUILD):
	mkdir -p $(BUILD)

clean:
	rm -rf $(BUILD)

run: all
	@for test in $(ALL_BINS); do \
		echo "Running $$test..."; \
		./$$test || exit 1; \
	done

.PHONY: all clean run
