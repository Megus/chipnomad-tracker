# Makefile for ChipNomad tests

# Compiler settings
CXX = c++
CFLAGS = -std=c++17 -Wall -g -O0
LDFLAGS = -lm -lstdc++

# Build directory
BUILD_DIR = build/tests

# Include paths
INCLUDES = -I. -Isrc -Isrc/corelib -Isrc/screens -Isrc/import -Itests/mocks -Iexternal \
           -I../chipnomad_lib -I../chipnomad_lib/chips -I../chipnomad_lib/external/ayumi

# Test executable
TEST_EXECUTABLE = $(BUILD_DIR)/run_tests

# Test source files
# NOTE: test_project_io.cpp is excluded due to global state issues causing crashes
# in unified executable. Will be fixed during C++ migration with proper DI.
TEST_SOURCES = tests/test_main.cpp \
               tests/test_edit_common.cpp \
               tests/test_instrument_references.cpp \
               tests/test_instrument_swap.cpp \
               tests/test_playback.cpp \
               tests/test_project.cpp \
               tests/test_sample_encoding.cpp \
               tests/test_import_wav.cpp \
               tests/test_wavetable_io.cpp \
               tests/test_modulation.cpp

# Common sources needed by tests
COMMON_SOURCES = ../chipnomad_lib/project.cpp \
                 ../chipnomad_lib/project_instruments.cpp \
                 ../chipnomad_lib/project_io.cpp \
                 ../chipnomad_lib/project_instruments_io.cpp \
                 ../chipnomad_lib/chipnomad_lib.cpp \
                 ../chipnomad_lib/playback.cpp \
                 ../chipnomad_lib/playback_ay.cpp \
                 ../chipnomad_lib/playback_instruments.cpp \
                 ../chipnomad_lib/playback_modulation.cpp \
                 ../chipnomad_lib/playback_fx_ay.cpp \
                 ../chipnomad_lib/playback_fx_common.cpp \
                 ../chipnomad_lib/playback_fx_modulation.cpp \
                 ../chipnomad_lib/chips/chip_ay.cpp \
                 ../chipnomad_lib/external/ayumi/ayumi.cpp \
                 ../chipnomad_lib/external/ayumi/ayumi_filters.cpp \
                 ../chipnomad_lib/utils.cpp \
                 src/screens/edit_common.cpp \
                 src/project_utils.cpp \
                 src/pitch_table_utils.cpp \
                 src/corelib/corelib_file.cpp \
                 src/import/import_wav.cpp \
                 src/wavetable_io.cpp

# Mock sources
MOCK_SOURCES = $(wildcard tests/mocks/*.cpp)

# All sources
ALL_SOURCES = $(TEST_SOURCES) $(COMMON_SOURCES) $(MOCK_SOURCES)

# Default target: build and run all tests
all: $(TEST_EXECUTABLE)
	@$(TEST_EXECUTABLE)

# Build the test executable
$(TEST_EXECUTABLE): $(ALL_SOURCES)
	@mkdir -p $(BUILD_DIR)
	@echo "Building test executable..."
	@$(CXX) $(CFLAGS) $(INCLUDES) $(ALL_SOURCES) $(LDFLAGS) -o $(TEST_EXECUTABLE)
	@echo "Built: $(TEST_EXECUTABLE)"

# Clean build artifacts
clean:
	@rm -rf $(BUILD_DIR)

# Help
help:
	@echo "ChipNomad Test Suite"
	@echo "===================="
	@echo ""
	@echo "Makefile targets:"
	@echo "  make -f Makefile.test           Build and run all tests"
	@echo "  make -f Makefile.test clean     Remove build artifacts"
	@echo "  make -f Makefile.test help      Show this help"
	@echo ""
	@echo "Direct usage (doctest native filtering):"
	@echo "  $(TEST_EXECUTABLE)                        Run all tests"
	@echo "  $(TEST_EXECUTABLE) --test-case='*ADSR*'   Run tests matching pattern"
	@echo "  $(TEST_EXECUTABLE) --list-test-cases      List all test cases"
	@echo "  $(TEST_EXECUTABLE) --success              Show successful assertions"
	@echo "  $(TEST_EXECUTABLE) --help                 See all doctest options"

.PHONY: all clean help
