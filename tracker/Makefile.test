# Makefile for ChipNomad tests
# Uses wildcards for automatic source discovery - add new test files and they're automatically included!

# Compiler settings
CXX = c++
CFLAGS = -std=c++17 -Wall -g -O0
LDFLAGS = -lm -lstdc++

# Build directory
BUILD_DIR = build/tests

# Include paths
INCLUDES = -I. -Isrc -Isrc/corelib -Isrc/screens -Isrc/import -Itests/mocks -Iexternal \
           -I../chipnomad_lib -I../chipnomad_lib/chips -I../chipnomad_lib/external/ayumi

# Test executable
TEST_EXECUTABLE = $(BUILD_DIR)/run_tests

# Test source files - automatically discover all test_*.cpp except excluded ones
TEST_SOURCES_ALL = $(wildcard tests/test_*.cpp)
# Excluded tests (add more here if needed):
# - test_project_io.cpp: Global state issues (will fix during C++ migration)
# - test_screen_instrument.cpp: UI test, not yet integrated
TEST_SOURCES_EXCLUDED = tests/test_project_io.cpp tests/test_screen_instrument.cpp
TEST_SOURCES = $(filter-out $(TEST_SOURCES_EXCLUDED),$(TEST_SOURCES_ALL))

# Common sources needed by tests - use wildcards for automatic discovery
CHIPNOMAD_LIB_SOURCES = $(wildcard ../chipnomad_lib/*.cpp) \
                        $(wildcard ../chipnomad_lib/chips/*.cpp) \
                        $(wildcard ../chipnomad_lib/external/ayumi/*.cpp)

TRACKER_SRC_SOURCES = src/project_utils.cpp \
                      src/pitch_table_utils.cpp \
                      src/wavetable_io.cpp \
                      $(wildcard src/screens/edit_common.cpp) \
                      $(wildcard src/corelib/corelib_file.cpp) \
                      $(wildcard src/import/import_wav.cpp)

# Mock sources
MOCK_SOURCES = $(wildcard tests/mocks/*.cpp)

# Combined common sources
COMMON_SOURCES = $(CHIPNOMAD_LIB_SOURCES) $(TRACKER_SRC_SOURCES)

# All sources
ALL_SOURCES = $(TEST_SOURCES) $(COMMON_SOURCES) $(MOCK_SOURCES)

# Default target: build and run all tests
all: $(TEST_EXECUTABLE)
	@$(TEST_EXECUTABLE)

# Build the test executable
$(TEST_EXECUTABLE): $(ALL_SOURCES)
	@mkdir -p $(BUILD_DIR)
	@echo "Building test executable..."
	@$(CXX) $(CFLAGS) $(INCLUDES) $(ALL_SOURCES) $(LDFLAGS) -o $(TEST_EXECUTABLE)
	@echo "Built: $(TEST_EXECUTABLE)"

# Clean build artifacts
clean:
	@rm -rf $(BUILD_DIR)

# Help
help:
	@echo "ChipNomad Test Suite"
	@echo "===================="
	@echo ""
	@echo "Makefile targets:"
	@echo "  make -f Makefile.test           Build and run all tests"
	@echo "  make -f Makefile.test clean     Remove build artifacts"
	@echo "  make -f Makefile.test help      Show this help"
	@echo ""
	@echo "Direct usage (doctest native filtering):"
	@echo "  $(TEST_EXECUTABLE)                        Run all tests"
	@echo "  $(TEST_EXECUTABLE) --test-case='*ADSR*'   Run tests matching pattern"
	@echo "  $(TEST_EXECUTABLE) --list-test-cases      List all test cases"
	@echo "  $(TEST_EXECUTABLE) --success              Show successful assertions"
	@echo "  $(TEST_EXECUTABLE) --help                 See all doctest options"

.PHONY: all clean help debug
