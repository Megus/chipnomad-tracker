# Test makefile
CC = cc
CFLAGS = -std=c99 -Wall -g

# Directories
LIB_DIR = ../chipnomad_lib
TRACKER_DIR = src
UNITY_DIR = external/unity
MOCK_DIR = tests/mocks

# Include paths
INCLUDES = -I$(UNITY_DIR) \
           -I$(LIB_DIR) \
           -I$(LIB_DIR)/corelib \
           -I$(TRACKER_DIR) \
           -I$(TRACKER_DIR)/corelib \
           -I$(TRACKER_DIR)/screens \
           -Iplatforms/shared

# Unity
UNITY_SRC = $(UNITY_DIR)/unity.c

# Mock sources
MOCK_SRC = $(wildcard $(MOCK_DIR)/*.c)

# Library sources needed by tests
LIB_SRC = $(LIB_DIR)/project.c \
          $(LIB_DIR)/utils.c

# Tracker sources needed by tracker tests
TRACKER_SRC = $(TRACKER_DIR)/project_utils.c

# Build directory
BUILD = build/test

# Discover tests from both locations
LIB_TESTS = $(wildcard $(LIB_DIR)/tests/test_*.c)
TRACKER_TESTS = $(wildcard tests/test_*.c)

# Test executables
LIB_TEST_BINS = $(patsubst $(LIB_DIR)/tests/test_%.c,$(BUILD)/test_lib_%,$(LIB_TESTS))
TRACKER_TEST_BINS = $(patsubst tests/test_%.c,$(BUILD)/test_%,$(TRACKER_TESTS))
ALL_BINS = $(LIB_TEST_BINS) $(TRACKER_TEST_BINS)

all: $(ALL_BINS)

# Library tests: lib sources + unity + mocks
$(BUILD)/test_lib_%: $(LIB_DIR)/tests/test_%.c $(LIB_SRC) $(UNITY_SRC) $(MOCK_SRC) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $< $(LIB_SRC) $(UNITY_SRC) $(MOCK_SRC) -lm

# Tracker tests: lib + tracker sources + unity + mocks
$(BUILD)/test_%: tests/test_%.c $(LIB_SRC) $(TRACKER_SRC) $(UNITY_SRC) $(MOCK_SRC) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $< $(LIB_SRC) $(TRACKER_SRC) $(UNITY_SRC) $(MOCK_SRC) -lm

$(BUILD):
	mkdir -p $(BUILD)

clean:
	rm -rf $(BUILD)

run: all
	@for test in $(ALL_BINS); do \
		echo "Running $$test..."; \
		./$$test || exit 1; \
	done

.PHONY: all clean run
