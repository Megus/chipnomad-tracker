# Test makefile
CC = cc
CFLAGS = -std=c99 -Wall -g

# Directories
LIB_DIR = ../chipnomad_lib
TRACKER_DIR = src
UNITY_DIR = external/unity
MOCK_DIR = tests/mocks
TEST_DIR = tests

# Include paths
INCLUDES = -I$(UNITY_DIR) \
           -I$(LIB_DIR) \
           -I$(LIB_DIR)/corelib \
           -I$(LIB_DIR)/corelib_file_stdio \
           -I$(TRACKER_DIR) \
           -I$(TRACKER_DIR)/corelib \
           -I$(TRACKER_DIR)/screens \
           -I$(TRACKER_DIR)/import \
           -Iplatforms/shared

# Unity
UNITY_SRC = $(UNITY_DIR)/unity.c

# Mock sources (only corelib mocks - platform-specific code)
CORELIB_MOCKS = $(MOCK_DIR)/corelib_audio_mock.c \
                $(MOCK_DIR)/corelib_file_mock.c \
                $(MOCK_DIR)/corelib_gfx_mock.c \
                $(MOCK_DIR)/corelib_input_mock.c \
                $(MOCK_DIR)/corelib_mainloop_mock.c

# Source directories (same as app, but exclude platform SDL code and corelib_file_stdio which we mock)
APP_SRC_DIRS = src \
               src/screens \
               src/import \
               src/corelib \
               ../chipnomad_lib \
               ../chipnomad_lib/chips \
               ../chipnomad_lib/external/ayumi \
               ../chipnomad_lib/export \
               platforms/shared

# Collect all app source files (exclude main.c which has its own main())
ALL_APP_SRC = $(filter-out platforms/shared/main.c, $(foreach dir, $(APP_SRC_DIRS), $(wildcard $(dir)/*.c)))

# Real file I/O (for test_project_io which tests actual file operations)
REAL_FILE_SRC = $(LIB_DIR)/corelib_file_stdio/corelib_file_stdio.c

# Minimal library sources for simple tests
LIB_SRC = $(LIB_DIR)/project.c \
          $(LIB_DIR)/project_io.c \
          $(LIB_DIR)/project_instruments.c \
          $(LIB_DIR)/project_instruments_io.c \
          $(LIB_DIR)/utils.c

# Build directory
BUILD = build/test

# All test files
ALL_TESTS = $(wildcard $(TEST_DIR)/test_*.c)

# Test executables
ALL_BINS = $(patsubst $(TEST_DIR)/test_%.c,$(BUILD)/test_%,$(ALL_TESTS))

all: $(ALL_BINS)

# Playback tests need the full playback engine
$(BUILD)/test_playback: $(TEST_DIR)/test_playback.c $(ALL_APP_SRC) $(UNITY_SRC) $(CORELIB_MOCKS) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -I$(MOCK_DIR) -o $@ $< $(ALL_APP_SRC) $(UNITY_SRC) $(CORELIB_MOCKS) -lm

# Project I/O tests use real file system (not mocked)
$(BUILD)/test_project_io: $(TEST_DIR)/test_project_io.c $(LIB_SRC) $(REAL_FILE_SRC) $(UNITY_SRC) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $< $(LIB_SRC) $(REAL_FILE_SRC) $(UNITY_SRC) -lm

# Project tests use minimal library sources (no tracker code needed)
$(BUILD)/test_project: $(TEST_DIR)/test_project.c $(LIB_SRC) $(UNITY_SRC) $(CORELIB_MOCKS) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -o $@ $< $(LIB_SRC) $(UNITY_SRC) $(CORELIB_MOCKS) -lm

# Default rule for other tests: use ALL_APP_SRC (simplest approach)
$(BUILD)/test_%: $(TEST_DIR)/test_%.c $(ALL_APP_SRC) $(UNITY_SRC) $(CORELIB_MOCKS) | $(BUILD)
	$(CC) $(CFLAGS) $(INCLUDES) -I$(MOCK_DIR) -o $@ $< $(ALL_APP_SRC) $(UNITY_SRC) $(CORELIB_MOCKS) -lm

$(BUILD):
	mkdir -p $(BUILD)

clean:
	rm -rf $(BUILD)

run: all
	@for test in $(ALL_BINS); do \
		echo "Running $$test..."; \
		./$$test || exit 1; \
	done

.PHONY: all clean run
